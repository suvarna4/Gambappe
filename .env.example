# Receipts environment variables — complete enumeration per design doc Appendix B.
# Secrets never live in the repo; platforms inject them (§18).

# --- Stores ---
DATABASE_URL=postgres://receipts:receipts@localhost:5432/receipts
REDIS_URL=redis://localhost:6379

# --- App ---
# The user-facing product name is NOT an env var — it is PRODUCT_NAME in
# packages/core/src/config.ts (single source; change it there to rebrand).
APP_NAME=Gambappe
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (Auth.js §11.1) ---
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# --- Email (Resend §13.2) ---
RESEND_API_KEY=
EMAIL_FROM=

# HMAC key for hashing ghost cookie secrets at rest (§6.1.1).
# The stored hash is HMAC-SHA256(secret, GHOST_COOKIE_SECRET) — one pinned scheme, never plain
# SHA-256. NOTE: effectively NON-ROTATABLE — rotating this value logs out every ghost.
GHOST_COOKIE_SECRET=

# Shared bearer secret for worker -> web internal calls (§2.4, §9.2 /internal/revalidate).
INTERNAL_API_SECRET=

# P0-only admin stopgap auth (§19.5, WS10-T1): strong random bearer (32+ bytes) + IP allowlist.
# Removed at P1 when Auth.js role auth replaces it.
ADMIN_STOPGAP_TOKEN=
ADMIN_STOPGAP_IP_ALLOWLIST=

# HMAC key for wallet_links.address_hash (§5.6, §12.5).
WALLET_HASH_SECRET=

# Signs ?r= share attribution tokens (§10.5).
SHARE_TOKEN_SECRET=

# HMAC key signing one-click unsubscribe tokens (§13.2 List-Unsubscribe link, WS9-T1).
# Added by WS9-T1 — not in the doc's original Appendix B list (see that task's PR notes: the
# ProfileSettings PATCH endpoint requires a claimed session, which a mail client's one-click
# link/POST can't supply, so a signed stateless token is the unsubscribe mechanism instead).
# Read by BOTH apps/worker (signs the link when sending) and apps/web (verifies it on click).
UNSUB_TOKEN_SECRET=

# --- Venues (§7) ---
KALSHI_API_BASE=
POLYMARKET_GAMMA_BASE=
POLYMARKET_CLOB_BASE=
POLYMARKET_DATA_BASE=
POLYGON_RPC_URL=
# Referral query params for outbound links (§7.8); empty until programs approved.
KALSHI_REF_PARAM=
POLYMARKET_REF_PARAM=

# --- Web push (§13.2) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Observability (§16) ---
SENTRY_DSN=

# --- Feature flags (§4.6): FLAG_<NAME>=true to enable; defaults in packages/core/src/flags.ts ---
FLAG_CONFIDENCE_SLIDER=
FLAG_DUO_QUEUE=
FLAG_WALLET_LINKING=
FLAG_WEB_PUSH=
FLAG_NEMESIS=
FLAG_DIVERGENCE_DISPLAY=
FLAG_KALSHI_WS_TICKER=
FLAG_HOUSES=
FLAG_PASSKEYS=

# --- Dev/staging only ---
ADMIN_SEED_EMAIL=

# NOTE (Appendix B): the analytics IP-hash salt is NOT an env secret — it is a per-day random
# value generated into Redis and discarded on rotation (§5.6), so no persisted secret can ever
# reverse the IPv4 space.

# Test-only (§17.2): core/clock.ts honors TEST_CLOCK when NODE_ENV=test or TEST_CLOCK_ENABLED=1.
# TEST_CLOCK=2026-07-19T16:00:00Z
