{
  "name": "@receipts/sim",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CPU-nemesis training simulator (docs/plans/cpu-nemesis-wbs.md T14): replays historical binary-market rows through pick policies and scores them. Node-only tooling — never bundled into web or worker.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@receipts/core": "workspace:*",
    "@receipts/engine": "workspace:*"
  },
  "devDependencies": {
    "@receipts/config": "workspace:*",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
