{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false
    }
  },
  "globalEnv": ["NODE_ENV", "TEST_CLOCK", "TEST_CLOCK_ENABLED"],
  "globalPassThroughEnv": ["DATABASE_URL", "REDIS_URL", "CI"]
}
